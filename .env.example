# LAN-hosted LM Studio/OpenAI-compatible chat completions endpoint.
# Use the IP address of the machine running LM Studio when it is on another device.
LLM_API_URL=http://<lm-studio-host-ip>:1234/v1/chat/completions

# Local model loaded in LM Studio.
LLM_MODEL=qwen3.5-9b-sft-claude-opus-reasoning-unsloth

# Local Faster Whisper model used for speech transcription.
WHISPER_MODEL=medium
